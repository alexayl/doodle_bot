digraph DoodlebotStateMachine {
  rankdir=LR;
  labelloc="t";
  node [shape=ellipse, fontname="Helvetica"];

  Start [shape=point];

  // States
  Init;
  Idle;
  Actuate;
  Error;

  // Start
  Start -> Init;
  Init -> Idle      [label="InitSuccess"];
  Init -> Error     [label="InitError"];

  // Normal flow
  Idle -> Actuate   [label="ReceiveVldCmd"];
  Idle -> Error     [label="ReceiveInvldCmd"];

  Actuate -> Idle   [label="EmptyCmdQueue"];
  Actuate -> Error  [label="BadActuation"];

  Error -> Init     [label="HardwareReset"];

}
